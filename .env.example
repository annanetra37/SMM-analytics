# Instagram Graph API credentials
# Get these from https://developers.facebook.com/
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# Meta Ads API (optional — for boost/ad strategy analytics)
# Find your Ad Account ID in Meta Business Suite > Settings > Ad Account
# Format: act_XXXXXXXXX (include the act_ prefix)
# Your access token needs the 'ads_read' permission
META_AD_ACCOUNT_ID=act_your_ad_account_id_here
